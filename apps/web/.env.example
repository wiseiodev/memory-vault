# Inngest local development
INNGEST_DEV="1"

# Inngest cloud mode
# INNGEST_EVENT_KEY="evt_your_event_key"
# INNGEST_SIGNING_KEY="signkey_your_signing_key"
# INNGEST_SIGNING_KEY_FALLBACK="signkey_your_fallback_signing_key"

# Optional when using a non-default Inngest dev server port
# INNGEST_BASE_URL="http://localhost:8288"

# AI Gateway extraction + embeddings
# AI Gateway auth uses this API key for Vercel AI SDK requests, including
# extraction fallback and segment embedding generation.
# AI_GATEWAY_API_KEY="vgw_your_ai_gateway_api_key"
