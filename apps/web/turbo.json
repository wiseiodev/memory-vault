{
  "extends": ["//"],
  "tasks": {
    "build": {
      "env": [
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "DATABASE_URL",
        "DATABASE_URL_UNPOOLED",
        "POSTGRES_URL",
        "POSTGRES_URL_NON_POOLING",
        "VERCEL_URL"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env.local", ".env.*"]
